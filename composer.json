{
    "name": "sentinel/sentinel",
    "description": "Self-hosted security monitoring framework. Event tracking, threat detection, and risk scoring for web applications.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Sentinel Security",
            "email": "security@sentinel.local"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Sentinel\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sentinel\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
