# Sentinel Configuration
# Copy this file to .env and update the values

# Application
APP_NAME=Sentinel
APP_ENV=development
APP_URL=http://localhost:8585
APP_SECRET=change_this_to_a_random_64_char_string

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=sentinel
DB_USER=sentinel
DB_PASS=sentinel_secret_2026

# Risk Engine
RISK_THRESHOLD_FLAG=60
RISK_THRESHOLD_SUSPEND=85

# Queue (disabled - Redis removed)
QUEUE_ENABLED=false

# Session
SESSION_LIFETIME=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120
